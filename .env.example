# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://rp-contoso-demos-apim.azure-api.net/rp-contoso-demos-resource
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Paths
DOCS_DIR=docs
DATA_DIR=data

# GENESIS-Online API (optional — free registration at destatis.de)
# Enables real-time macroeconomic data lookups (GDP, population, inflation)
# Register: https://www-genesis.destatis.de/datenbank/online/#modal=login,register
# GENESIS_API_TOKEN=your-api-token-here
# GENESIS_USERNAME=your-username
# GENESIS_PASSWORD=your-password
